{
  "protocol_name": "ProbLLM main-table protocol",
  "paper_scope": "Matched five-seed MF and LightGCN main-table runs",
  "seeds": [42, 2020, 2021, 2022, 2023],
  "shared": {
    "warmup_k": 5,
    "top_k": 20,
    "embedding_dimension": 200,
    "lightgcn_layers": 2,
    "l2_decay": 0.0001,
    "evaluation_batch_size": 512,
    "lora": {
      "base_model": "LLaMA-2-7B",
      "template": "LLaMA-2",
      "cutoff_length": 1024,
      "epochs": 2,
      "rank": 8,
      "alpha": 16,
      "dropout": 0.0,
      "learning_rate": 0.0001,
      "scheduler": "cosine",
      "warmup_ratio": 0.1,
      "per_device_batch_size": 1,
      "gradient_accumulation_steps": 8,
      "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"]
    }
  },
  "settings": {
    "citeulike_item": {
      "dataset": "CiteULike",
      "cold_object": "item",
      "retrieval_query": "warm_user",
      "candidate_budget": 50,
      "selection_rule": "Select 20 cold items per warm-query user by the validation-fixed fused rank, then pool selected incident edges by cold-item endpoint.",
      "selection_budget": 20,
      "score_readout": "normalized next-token logits for labels 0 and 1",
      "reliability_encoding": "normalized within-query fused-rank encoding",
      "rwft_beta": 0.25,
      "caga_gamma": 0.01,
      "caga_target_object": "item",
      "evaluation_candidate_mode": "group",
      "warm_checkpoint_epochs": 200,
      "final_epochs": 60,
      "final_learning_rate": 0.00001,
      "final_bpr_batch": 4096,
      "target_only_update": false,
      "score_prior": {"required": false}
    },
    "movielens_item": {
      "dataset": "ml-1m",
      "cold_object": "item",
      "retrieval_query": "cold_item",
      "candidate_budget": 20,
      "selection_rule": "Construct graph pseudo-edges from the valid generated scores in the K=20 target-edge pool under the validation-fixed rule.",
      "selection_budget": "valid scored candidates",
      "score_readout": "first valid generated value in [0,1] for graph pseudo-edges; normalized next-token logits for the separate score prior",
      "reliability_encoding": "direct generated score for graph pseudo-edges",
      "rwft_beta": 0.8,
      "caga_gamma": 0.05,
      "caga_target_object": "item",
      "evaluation_candidate_mode": "group",
      "warm_checkpoint_epochs": 200,
      "final_epochs": 60,
      "final_learning_rate": 0.001,
      "final_bpr_batch": 4096,
      "target_only_update": true,
      "score_prior": {
        "required": true,
        "candidate_budget": 100,
        "coefficient": 0.9,
        "application": "Added only to final ranking scores after graph training; it is not a pseudo-edge and receives no gradient update."
      }
    },
    "movielens_user": {
      "dataset": "ml-1m",
      "cold_object": "user",
      "retrieval_query": "cold_user",
      "candidate_budget": 50,
      "selection_rule": "Select 20 warm-item candidates per cold-user query by the validation-fixed filter/refiner rank rule.",
      "selection_budget": 20,
      "score_readout": "first valid generated value in [0,1]",
      "reliability_encoding": "normalized within-query rank encoding",
      "rwft_beta": 0.8,
      "caga_gamma": 0.3,
      "caga_target_object": "user",
      "evaluation_candidate_mode": "full",
      "warm_checkpoint_epochs": 200,
      "final_epochs": 60,
      "final_learning_rate": 0.001,
      "final_bpr_batch": 4096,
      "target_only_update": false,
      "score_prior": {"required": false}
    },
    "bookcrossing_user": {
      "dataset": "book-crossing_user",
      "cold_object": "user",
      "retrieval_query": "cold_user",
      "candidate_budget": 50,
      "selection_rule": "Retain 10 warm-item candidates per cold-user query using the validation-fixed strict/warm-up branch rule.",
      "selection_budget": 10,
      "score_readout": "first valid generated value in [0,1]",
      "reliability_encoding": "normalized within-query rank encoding",
      "rwft_beta": 0.8,
      "caga_gamma": 1.0,
      "caga_target_object": "user",
      "evaluation_candidate_mode": "full",
      "warm_checkpoint_epochs": 200,
      "final_epochs": 100,
      "final_learning_rate": 0.001,
      "final_bpr_batch": 4096,
      "target_only_update": false,
      "score_prior": {"required": false}
    }
  }
}
